@using WorkspaceJarvis.Models
@using WorkspaceJarvis.Utilities
@inherits MudComponentBase

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@(ExistingWorkspace == null ? Icons.Material.Filled.Add : Icons.Material.Filled.Edit)" Class="mr-3" />
            @(ExistingWorkspace == null ? "Add New Workspace" : "Edit Workspace")
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudTextField T="string" Label="Workspace Name" @bind-Value="workspaceModel.Name" Required="true" Class="mb-4" />

        <MudText Typo="Typo.subtitle2" Class="mb-2">Included Apps & Files</MudText>

        @* Scrollable Container *@
        <div style="max-height: 300px; overflow-y: auto; border: 1px solid var(--mud-palette-lines-inputs); border-radius: 4px; padding: 8px;">
            <MudList T="string" Clickable="false">
                @if (!workspaceModel.Paths.Any())
                {
                    <MudListItem Text="No paths added yet" Icon="@Icons.Material.Filled.Info" />
                }
                else
                {
                    @foreach (var path in workspaceModel.Paths)
                    {
                        var iconSource = AppUtils.GetIconBase64(path);

                        <MudListItem>
                            <div class="d-flex align-center justify-space-between w-100">
                                <div class="d-flex align-center" style="overflow: hidden;">

                                    @* ICON DISPLAY *@
                                    @if (iconSource == "LINK_ICON")
                                    {
                                        <MudIcon Icon="@Icons.Material.Filled.Public" Color="Color.Info" Class="mr-3" />
                                    }
                                    else if (!string.IsNullOrEmpty(iconSource))
                                    {
                                        <img src="@iconSource" style="width: 24px; height: 24px; margin-right: 12px;" />
                                    }
                                    else
                                    {
                                        <MudIcon Icon="@Icons.Material.Filled.InsertDriveFile" Class="mr-3" />
                                    }

                                    <div class="d-flex flex-column">
                                        <MudText Typo="Typo.body1" Class="fw-bold text-truncate">
                                            @AppUtils.GetFriendlyName(path)
                                        </MudText>
                                        <MudText Typo="Typo.caption" Class="text-truncate" Style="opacity: 0.6;">
                                            @path
                                        </MudText>
                                    </div>
                                </div>

                                <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                               Color="Color.Error"
                                               Size="Size.Small"
                                               OnClick="@(() => RemovePath(path))" />
                            </div>
                        </MudListItem>
                    }
                }

                @* Add Button at the bottom of the list *@
                <MudListItem OnClick="BrowseFiles" Icon="@Icons.Material.Filled.AddCircle" IconColor="Color.Primary">
                    <MudText Color="Color.Primary">Add App or File...</MudText>
                </MudListItem>
            </MudList>
        </div>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Color="Color.Primary" OnClick="Submit">
            @(ExistingWorkspace == null ? "Create" : "Update")
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = default!;

    [Parameter] public Workspace? ExistingWorkspace { get; set; }

    // This is our "working copy" for the form
    private Workspace workspaceModel = new();

    protected override void OnParametersSet()
    {
        if (ExistingWorkspace != null)
        {
            // Pre-fill the form with existing data
            workspaceModel = new Workspace
            {
                Id = ExistingWorkspace.Id,
                Name = ExistingWorkspace.Name,
                // Create a copy of the paths so we don't modify the UI list prematurely
                Paths = new List<string>(ExistingWorkspace.Paths)
            };
        }
    }

    private void Cancel() => MudDialog.Cancel();

    private void Submit()
    {
        // Simple validation: Ensure Name isn't empty
        if (string.IsNullOrWhiteSpace(workspaceModel.Name)) return;

        // The paths are already in workspaceModel.Paths from the BrowseFiles logic

        MudDialog.Close(DialogResult.Ok(workspaceModel));
    }

    private async Task BrowseFiles()
    {
        try
        {
            var result = await FilePicker.Default.PickAsync(new PickOptions
            {
                PickerTitle = "Select an Application or File"
            });

            if (result != null)
            {
                // Prevent duplicate paths
                if (!workspaceModel.Paths.Contains(result.FullPath))
                {
                    workspaceModel.Paths.Add(result.FullPath);
                }
            }
        }
        catch (Exception ex)
        {
            // Handle cases where the picker fails or is cancelled
            Console.WriteLine($"File picking failed: {ex.Message}");
        }
    }

    private void RemovePath(string path)
    {
        workspaceModel.Paths.Remove(path);
    }
}