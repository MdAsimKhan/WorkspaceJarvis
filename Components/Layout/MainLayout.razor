@inherits LayoutComponentBase

<MudThemeProvider Theme="@MyCustomTheme" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="1">
        <MudText Typo="Typo.h6">Workspace Jarvis</MudText>
    </MudAppBar>
    <MudMainContent Class="app-main-content">
        <MudContainer MaxWidth="MaxWidth.Medium" Class="app-content pa-6">
            @Body
        </MudContainer>
    </MudMainContent>
</MudLayout>

@code {
    MudTheme MyCustomTheme = new MudTheme();
}
