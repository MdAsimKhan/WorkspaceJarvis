@page "/"
@using WorkspaceJarvis.UI.Models
@using WorkspaceJarvis.UI.Services
@inject WorkspaceService WorkspaceService
@inject IDialogService DialogService
@inject ISnackbar Snackbar

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="main-viewport py-4">

    <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="sticky-header mb-4 px-4">
        <MudText Typo="Typo.h5" Style="color: #2c2c2c; font-weight: 800; letter-spacing: 1px;">YOUR WORKSPACES</MudText>

        <MudButton Variant="Variant.Filled"
                   StartIcon="@Icons.Material.Filled.Add"
                   Color="Color.Info"
                   Size="Size.Large"
                   OnClick="OpenAddDialog"
                   Style="border-radius: 12px; font-weight: 700; text-transform: none;">
            Add Workspace
        </MudButton>
    </MudStack>

    <MudPaper Outlined="true" Class="scrollable-grid-container">
        <div class="scrollable-grid-content">
            <MudGrid Spacing="4">
            @foreach (var ws in workspaces)
            {
                <MudItem xs="12" sm="6" md="4" lg="2">
                    <MudCard Class="workspace-card pa-3 d-flex flex-column justify-space-between">
                        <MudStack Row="true" Justify="Justify.SpaceBetween">
                            <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                            Color="Color.Error"
                                            Size="Size.Small"
                                            OnClick="@(() => OnDeleteClicked(ws))" />
                            <MudIconButton Icon="@Icons.Material.Filled.EditNote"
                                            Color="Color.Info"
                                            Size="Size.Small"
                                            OnClick="@(() => OpenEditDialog(ws))" />
                        </MudStack>

                        <MudStack AlignItems="AlignItems.Center" Spacing="0">
                            <MudText Typo="Typo.subtitle2" Class="fw-bold text-uppercase">@ws.Name</MudText>
                            <MudText Typo="Typo.caption">Apps: @ws.Paths.Count</MudText>
                        </MudStack>

                        <MudButton Variant="Variant.Filled" Class="launch-btn" @onclick="() => WorkspaceService.Launch(ws)">
                            Launch
                        </MudButton>
                    </MudCard>
                </MudItem>
            }
            </MudGrid>
        </div>
    </MudPaper>
</MudContainer>

@code {
    private List<Workspace> workspaces = new();

    protected override void OnInitialized()
    {
        workspaces = WorkspaceService.GetWorkspaces();
    }

    private async Task OpenAddDialog()
    {
        var dialog = await DialogService.ShowAsync<AddWorkspaceDialog>("Add New Workspace");
        // 1. Rename the dialog result to 'dialogResult'
        var dialogResult = await dialog.Result;

        if (!dialogResult.Canceled && dialogResult.Data is Workspace newWs)
        {
            // 2. Rename the service result to 'saveResult'
            var saveResult = WorkspaceService.SaveWorkspace(newWs);

            if (saveResult.Success)
            {
                Snackbar.Add(saveResult.Message, Severity.Success);
                workspaces = WorkspaceService.GetWorkspaces();
            }
        }
    }

    private async Task OpenEditDialog(Workspace ws)
    {
        // Capture the name before the user edits it


        var parameters = new DialogParameters<AddWorkspaceDialog>
        {
            { x => x.ExistingWorkspace, ws }
        };

        var dialog = await DialogService.ShowAsync<AddWorkspaceDialog>("Edit Workspace", parameters);
        var result = await dialog.Result;

        if (!result.Canceled && result.Data is Workspace updatedWs)
        {
            // Call the service using both the old identifier and the new data
            var updateResult = WorkspaceService.UpdateWorkspace(updatedWs);

            if (updateResult.Success)
            {
                Snackbar.Add(updateResult.Message, Severity.Success);
                workspaces = WorkspaceService.GetWorkspaces(); // Refresh UI
            }
            else
            {
                Snackbar.Add(updateResult.Message, Severity.Error);
            }
        }
    }

    private async Task OnDeleteClicked(Workspace ws)
    {
        // 1. Ask for confirmation
        bool? result = await DialogService.ShowMessageBoxAsync(
            "Warning",
            $"Are you sure you want to delete the workspace '{ws.Name}'?",
            yesText: "Delete!", cancelText: "Cancel");

        // 2. Process the result
        if (result == true)
        {
            var deleteResult = WorkspaceService.DeleteWorkspace(ws.Id);

            if (deleteResult.Success)
            {
                Snackbar.Add(deleteResult.Message, Severity.Success);
                // Refresh the grid
                workspaces = WorkspaceService.GetWorkspaces();
            }
            else
            {
                Snackbar.Add(deleteResult.Message, Severity.Error);
            }
        }
    }
}
